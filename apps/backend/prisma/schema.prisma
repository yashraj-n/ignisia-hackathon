generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Company {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  login_email    String
  login_password String
  size           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Competitor {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  s3_url   String
  information String 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
